# ────────────────────────────────────────────────────────
# Trading Engine Configuration
# Copy to .env and fill in your values
# ────────────────────────────────────────────────────────

# JWT & Security
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-me-in-production

# Database
DATABASE_URL=sqlite:///./trades.db

# Broker Integration
BROKER=FYERS  # Options: FYERS, DHAN
PAPER_TRADING=true
AVAILABLE_CASH=200000

# FYERS Broker (if using FYERS)
FYERS_APP_ID=your-fyers-app-id
FYERS_SECRET_KEY=your-fyers-secret-key
FYERS_ACCESS_TOKEN=your-fyers-access-token

# DHAN Broker (if using DHAN)
DHAN_ACCESS_TOKEN=your-dhan-access-token
DHAN_CLIENT_ID=your-dhan-client-id

# Email Alerts (Gmail)
# For Gmail: use App Password (not main password)
# Enable 2FA first: https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password

# Telegram Alerts
# Get from @BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# API Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Logging
LOG_LEVEL=INFO
LOG_FILE=trading.log
